# ─────────────────────────────────────────────────────────────────────────────
# FURPMS Backend — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5068
APP_NAME=FURPMS
APP_URL=https://furpms-api-production.up.railway.app
FRONTEND_URL=https://furpms.vercel.app

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from: MongoDB Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/furpms?retryWrites=true&w=majority&appName=furpms

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_min_64_hex_chars_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_min_64_hex_chars_refresh_secret
# Seconds: 86400 = 1 day, 604800 = 7 days
JWT_ACCESS_EXPIRY=86400
JWT_REFRESH_EXPIRY=604800

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Nodemailer / Gmail) ────────────────────────────────────────────────
# Gmail: enable 2FA → App Passwords → generate password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=noreply@furpms.edu.vn
EMAIL_FROM_NAME=FURPMS System

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get from: aistudio.google.com → API Keys
GEMINI_API_KEY=your_gemini_api_key

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# windowMs in milliseconds: 900000 = 15 minutes
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window per IP
RATE_LIMIT_MAX_REQUESTS=200

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL=info
# Only used in development (Railway uses stdout/stderr)
LOG_DIR=logs

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Business Config ───────────────────────────────────────────────────────────
# Base daily salary (VND) — can be overridden by FinancialConfig documents in DB
BASE_DAILY_SALARY=1490000
